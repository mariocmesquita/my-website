// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Prisma 7: client is generated at apps/api/generated/prisma
// Import in services with: import { PrismaClient } from '../../generated/prisma'
generator client {
    provider     = "prisma-client"
    output       = "../generated/prisma/client"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model Career {
    id        String    @id @db.Uuid
    company   String    @db.VarChar(100)
    role      String    @db.VarChar(100)
    startDate DateTime  @map("start_date") @db.Date
    endDate   DateTime? @map("end_date") @db.Date
    content   String    @db.Text
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@map("careers")
}

model Project {
    id          String   @id @db.Uuid
    title       String   @db.VarChar(200)
    slug        String   @unique @db.VarChar(200)
    summary     String   @db.VarChar(300)
    description String   @db.Text
    bannerImage String?  @map("banner_image") @db.Text
    screenshots Json     @default("[]")
    githubLink  String?  @map("github_link") @db.Text
    techStack   Json     @default("[]") @map("tech_stack")
    publishDate DateTime @map("publish_date") @db.Date
    archived    Boolean  @default(false)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    @@map("projects")
}

model Profile {
    id          String   @id @db.Uuid
    name        String   @db.VarChar(50)
    position    String   @db.VarChar(50)
    description String   @db.VarChar(130)
    bio         String   @db.VarChar(1000)
    email       String   @db.VarChar(50)
    socialLinks Json     @default("{}")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    @@map("profiles")
}
