// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Prisma 7: client is generated at apps/api/generated/prisma
// Import in services with: import { PrismaClient } from '../../generated/prisma'
generator client {
    provider     = "prisma-client"
    output       = "../generated/prisma/client"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model Career {
    id        String    @id @db.Uuid
    company   String    @db.VarChar(100)
    role      String    @db.VarChar(100)
    startDate DateTime  @map("start_date") @db.Date
    endDate   DateTime? @map("end_date") @db.Date
    content   String    @db.Text
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    translations CareerTranslation[]

    @@map("careers")
}

model CareerTranslation {
    id        String   @id @db.Uuid
    careerId  String   @map("career_id") @db.Uuid
    locale    String   @db.VarChar(5)
    role      String   @db.VarChar(100)
    content   String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

    @@unique([careerId, locale])
    @@map("career_translations")
}

model Project {
    id          String   @id @db.Uuid
    title       String   @db.VarChar(200)
    slug        String   @unique @db.VarChar(200)
    summary     String   @db.VarChar(300)
    description String   @db.Text
    bannerImage String?  @map("banner_image") @db.Text
    screenshots Json     @default("[]")
    githubLink  String?  @map("github_link") @db.Text
    techStack   Json     @default("[]") @map("tech_stack")
    publishDate DateTime @map("publish_date") @db.Date
    archived    Boolean  @default(false)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    posts        PostProject[]
    translations ProjectTranslation[]

    @@map("projects")
}

model ProjectTranslation {
    id          String   @id @db.Uuid
    projectId   String   @map("project_id") @db.Uuid
    locale      String   @db.VarChar(5)
    title       String   @db.VarChar(200)
    summary     String   @db.VarChar(300)
    description String   @db.Text
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@unique([projectId, locale])
    @@map("project_translations")
}

model Post {
    id          String    @id @db.Uuid
    title       String    @db.VarChar(200)
    slug        String    @unique @db.VarChar(200)
    summary     String    @db.VarChar(300)
    content     String    @db.Text
    bannerImage String?   @map("banner_image") @db.Text
    tags        Json      @default("[]")
    techStack   Json      @default("[]") @map("tech_stack")
    status      String    @default("draft") @db.VarChar(20)
    publishDate DateTime? @map("publish_date") @db.Date
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @updatedAt @map("updated_at")

    projects     PostProject[]
    likes        PostLike[]
    translations PostTranslation[]

    @@map("posts")
}

model PostTranslation {
    id        String   @id @db.Uuid
    postId    String   @map("post_id") @db.Uuid
    locale    String   @db.VarChar(5)
    title     String   @db.VarChar(200)
    summary   String   @db.VarChar(300)
    content   String   @db.Text
    tags      Json     @default("[]")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@unique([postId, locale])
    @@map("post_translations")
}

model PostLike {
    id        String   @id @db.Uuid
    postId    String   @map("post_id") @db.Uuid
    visitorId String   @map("visitor_id") @db.VarChar(100)
    createdAt DateTime @default(now()) @map("created_at")

    post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@unique([postId, visitorId])
    @@map("post_likes")
}

model PostProject {
    postId    String @map("post_id") @db.Uuid
    projectId String @map("project_id") @db.Uuid

    post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
    project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    @@id([postId, projectId])
    @@map("post_projects")
}

model Profile {
    id          String   @id @db.Uuid
    name        String   @db.VarChar(50)
    position    String   @db.VarChar(50)
    description String   @db.VarChar(130)
    bio         String   @db.VarChar(1000)
    email       String   @db.VarChar(50)
    socialLinks Json     @default("{}")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    translations ProfileTranslation[]

    @@map("profiles")
}

model ProfileTranslation {
    id          String   @id @db.Uuid
    profileId   String   @map("profile_id") @db.Uuid
    locale      String   @db.VarChar(5)
    position    String   @db.VarChar(50)
    description String   @db.VarChar(130)
    bio         String   @db.VarChar(1000)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    @@unique([profileId, locale])
    @@map("profile_translations")
}

model AppLog {
    id        String   @id @db.Uuid
    level     String   @db.VarChar(20)
    eventType String   @map("event_type") @db.VarChar(50)
    message   String   @db.Text
    ip        String?  @db.VarChar(100)
    method    String?  @db.VarChar(10)
    path      String?  @db.VarChar(500)
    userAgent String?  @map("user_agent") @db.VarChar(500)
    createdAt DateTime @default(now()) @map("created_at")

    @@map("app_logs")
}
